{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@boundra/runtime": ["../../packages/runtime/src/index.ts"],
      "@domains/*": ["domains/*"]
    },
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "domains/**/*.ts"]
}
